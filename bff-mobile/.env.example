# ===========================================
# PayTrack BFF Mobile - Variáveis de Ambiente
# ===========================================
# Copie para .env: cp .env.example .env
#
# O BFF Mobile é uma camada intermediária entre o app Expo e o backend principal.
# Ele NÃO acessa o banco de dados diretamente — todas as chamadas passam pelo backend.

# -------------------------------------------
# Servidor
# -------------------------------------------
NODE_ENV=development

# Porta local de desenvolvimento (produção recebe PORT automaticamente da plataforma)
PORT=3001

# -------------------------------------------
# JWT
# -------------------------------------------
# IMPORTANTE: deve ser o MESMO valor que JWT_SECRET do backend.
# O BFF valida tokens emitidos pelo backend — ambos precisam compartilhar o mesmo secret.
# Gere com: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-key-change-in-production

# -------------------------------------------
# Backend
# -------------------------------------------
# URL do backend principal (NestJS)
# Desenvolvimento: http://localhost:3000
# Produção: URL pública do backend no Render/Railway
BACKEND_URL=http://localhost:3000

# -------------------------------------------
# CORS
# -------------------------------------------
# Origens permitidas separadas por vírgula.
# Apps mobile nativos (iOS/Android) não enviam cabeçalho Origin,
# portanto em produção este valor pode ficar vazio.
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
