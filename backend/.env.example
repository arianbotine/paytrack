# ===========================================
# PayTrack Backend - Variáveis de Ambiente
# ===========================================
# Copie para .env: cp .env.example .env
#
# NOTA: Este arquivo é específico do backend (NestJS).
# O docker-compose usa as variáveis DB_* do .env na raiz do repositório.

# -------------------------------------------
# Banco de Dados (Prisma)
# -------------------------------------------
# URL com connection pooler (usada em runtime pelo Prisma)
DATABASE_URL=postgresql://paytrack:paytrack123@localhost:5433/paytrack?schema=public

# URL direta sem pooler (necessária para `prisma migrate deploy` em produção com Neon)
# Em desenvolvimento local, pode ser igual a DATABASE_URL
# Em produção (Neon): use a URL sem "-pooler" no hostname
DIRECT_DATABASE_URL=postgresql://paytrack:paytrack123@localhost:5433/paytrack?schema=public

# Limite de conexões simultâneas (recomendado: 5-10 em planos gratuitos)
DATABASE_CONNECTION_LIMIT=10

# Timeout do pool em segundos
DATABASE_POOL_TIMEOUT=20

# -------------------------------------------
# Servidor
# -------------------------------------------
NODE_ENV=development

# Porta local de desenvolvimento (produção recebe PORT automaticamente da plataforma)
API_PORT=3000

# -------------------------------------------
# JWT
# -------------------------------------------
# Gere chaves seguras em produção: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production

# Expiração do access token (dev: 15m | produção recomendado: 7d)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# Google OAuth (login social via better-auth)
# -------------------------------------------
# URL base da própria API (usada pelo better-auth para montar o redirect URI OAuth)
API_URL=http://localhost:3000

# URL do frontend (usada no CORS e nos redirects pós-login)
FRONTEND_URL=http://localhost:5173

# Credenciais do Google OAuth 2.0
# Obtenha em: https://console.cloud.google.com/apis/credentials
# Redirect URI autorizado: {API_URL}/api/auth-social/callback/google
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# Segredo do better-auth (mínimo 32 caracteres)
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=mude-este-segredo-em-producao-minimo-32-chars

# -------------------------------------------
# CORS
# -------------------------------------------
# Origens permitidas separadas por vírgula
# Em produção: inclua a URL do frontend no Vercel e do BFF
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# -------------------------------------------
# Performance & Cache
# -------------------------------------------
# Timeout de requisições HTTP em milissegundos
REQUEST_TIMEOUT_MS=30000

# TTL do cache do dashboard em segundos
CACHE_TTL_DASHBOARD=300

# TTL das chaves de idempotência em segundos (1 hora)
IDEMPOTENCY_TTL=3600
