# ===========================================
# PayTrack Mobile - Variáveis de Ambiente (Expo)
# ===========================================
# Copie para .env: cp .env.example .env
#
# NOTA: Variáveis com prefixo EXPO_PUBLIC_ são embutidas no bundle pelo Metro
# e ficam acessíveis em runtime via process.env.EXPO_PUBLIC_*
#
# Em desenvolvimento, este arquivo é gerado automaticamente pelo Makefile
# com `make mobile-setup` a partir do MOBILE_HOST_IP no .env raiz.
#
# Em produção (EAS Build), configure as variáveis pelo painel do Expo:
# https://expo.dev/accounts/[account]/projects/paytrack/environment-variables

# -------------------------------------------
# BFF Mobile
# -------------------------------------------
# URL do BFF Mobile acessível pelo dispositivo físico ou emulador
# Desenvolvimento: http://{IP_LOCAL}:3001
# Produção: URL pública do BFF no Render/Railway
EXPO_PUBLIC_BFF_URL=http://192.168.1.100:3001

# -------------------------------------------
# Google OAuth
# -------------------------------------------
# Obtenha as credenciais em: https://console.cloud.google.com/apis/credentials
# Crie credenciais separadas por tipo (Web, Android, iOS).

# Client ID do tipo "Web" (usado pelo Google Sign-In no Expo Go e builds web)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=seu-web-client-id.apps.googleusercontent.com

# Client ID do tipo "Android" (usado em builds Android nativos)
# Tipo: "Android", Package: com.paytrack.mobile
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=seu-android-client-id.apps.googleusercontent.com

# Client ID do tipo "iOS" (usado em builds iOS nativos)
# Tipo: "iOS", Bundle ID: com.paytrack.mobile
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=seu-ios-client-id.apps.googleusercontent.com
