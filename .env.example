# ===========================================
# PayTrack - Variáveis de Orquestração Local
# ===========================================
# Este arquivo é usado APENAS pelo docker-compose e pelo Makefile.
# Cada app possui seu próprio .env.example com suas variáveis específicas.
#
# Copie para .env: cp .env.example .env

# -------------------------------------------
# Banco de Dados (PostgreSQL via docker-compose)
# -------------------------------------------
DB_USER=paytrack
DB_PASSWORD=paytrack123
DB_NAME=paytrack
DB_PORT=5433

# URL de conexão (usada pelo Makefile em `make db-sync` e `make studio`)
DATABASE_URL=postgresql://paytrack:paytrack123@localhost:5433/paytrack?schema=public

# -------------------------------------------
# Portas locais (usadas pelo Makefile para iniciar os serviços)
# -------------------------------------------
WEB_PORT=5173
BFF_PORT=3001

# -------------------------------------------
# Mobile App (Expo)
# IP do host acessível pelo celular (ex: IP Wi-Fi, ou IP WSL2 no Windows)
# Usado pelo `make mobile-setup` para gerar mobile/.env automaticamente
# -------------------------------------------
MOBILE_HOST_IP=192.168.1.100
