# ===========================================
# PayTrack - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e ajuste os valores conforme necessário
# cp .env.example .env

# -------------------------------------------
# Banco de Dados (PostgreSQL)
# -------------------------------------------
DB_USER=paytrack
DB_PASSWORD=paytrack123
DB_NAME=paytrack
DB_PORT=5433

# URL de conexão completa (usada pelo Prisma)
DATABASE_URL=postgresql://paytrack:paytrack123@localhost:5433/paytrack?schema=public

# -------------------------------------------
# Backend (NestJS)
# -------------------------------------------
NODE_ENV=development
API_PORT=3000

# JWT Configuration
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# Frontend (Vite/React)
# -------------------------------------------
WEB_PORT=5173
VITE_API_URL=http://localhost:3000

# -------------------------------------------
# BFF Mobile (Backend for Frontend)
# -------------------------------------------
BFF_PORT=3001
BACKEND_URL=http://localhost:3000
# BFF_JWT_SECRET usa JWT_SECRET por padrão

# -------------------------------------------
# Mobile App (Expo)
# IP do host acessível pelo celular (ex: IP Wi-Fi do Windows no WSL2)
# -------------------------------------------
MOBILE_HOST_IP=192.168.1.100
